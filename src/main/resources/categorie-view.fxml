<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biblio.controller.CategorieController" spacing="8" prefWidth="700" prefHeight="500">
    <padding>
        <Insets topRightBottomLeft="12"/>
    </padding>
    <Label text="Gestion des Catégories"/>
    <TableView fx:id="tableCategories" prefHeight="300.0">
        <columns>
            <TableColumn fx:id="colLibelle" text="Libellé" prefWidth="280"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="360"/>
        </columns>
    </TableView>
    <HBox spacing="8">
        <TextField fx:id="txtLibelle" promptText="Libellé de la catégorie"/>
        <TextField fx:id="txtDescription" promptText="Description"/>
        <Button text="Ajouter" onAction="#onAdd"/>
        <Button text="Supprimer" onAction="#onDelete"/>
    </HBox>
</VBox>
