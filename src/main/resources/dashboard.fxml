<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biblio.controller.DashboardController" spacing="16" prefWidth="900" prefHeight="600">
    <padding>
        <Insets topRightBottomLeft="16"/>
    </padding>
    <Label text="Tableau de bord" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <HBox spacing="16">
        <VBox fx:id="cardLivres" styleClass="card card-blue" alignment="CENTER">
            <Label text="📚 Total Livres"/>
            <Label fx:id="lblTotalLivres" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox fx:id="cardAdherents" styleClass="card card-green" alignment="CENTER">
            <Label text="👥 Total Adhérents"/>
            <Label fx:id="lblTotalAdherents" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox fx:id="cardRetards" styleClass="card card-red" alignment="CENTER">
            <Label text="⚠ Emprunts en retard"/>
            <Label fx:id="lblRetards" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>
    <Label text="Bienvenue dans le tableau de bord de la bibliothèque" styleClass="text-muted"/>
</VBox>
