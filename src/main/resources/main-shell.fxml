<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.biblio.controller.MainShellController" prefWidth="1000" prefHeight="700">
    <top>
        <HBox spacing="8" styleClass="header">
            <Label text="📚 Bibliothèque de Dakar" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUserName" />
            <Label fx:id="lblUserRole" styleClass="badge"/>
        </HBox>
    </top>
    <left>
        <VBox spacing="8" BorderPane.alignment="CENTER" styleClass="sidebar">
            <padding>
                <Insets topRightBottomLeft="12"/>
            </padding>
            <Label text="Menu"/>
            <Button text="🏠 Tableau de bord" onAction="#showDashboard" styleClass="menu-button"/>
            <Button text="📚 Livres" onAction="#showLivres" styleClass="menu-button"/>
            <Button text="👥 Adhérents" onAction="#showAdherents" styleClass="menu-button"/>
            <Button text="🕒 Emprunts" onAction="#showEmprunts" styleClass="menu-button"/>
            <Button fx:id="btnCategories" text="🗂 Catégories" onAction="#showCategories" styleClass="menu-button"/>
            <Button fx:id="btnUsers" text="👤 Utilisateurs" onAction="#showUsers" styleClass="menu-button"/>
            <Button text="🚪 Déconnexion" onAction="#onLogout" styleClass="menu-button"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="centerContainer">
            <VBox fx:id="dashboardRoot" spacing="16" alignment="TOP_LEFT" BorderPane.alignment="CENTER" style="-fx-padding: 16;">
                <Label text="Tableau de bord" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <HBox spacing="16">
                    <VBox fx:id="cardLivres" styleClass="card card-blue" alignment="CENTER" prefWidth="250" prefHeight="140">
                        <Label text="📚 Total Livres"/>
                        <Label fx:id="lblDashLivres" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox fx:id="cardAdherents" styleClass="card card-green" alignment="CENTER" prefWidth="250" prefHeight="140">
                        <Label text="👥 Total Adhérents"/>
                        <Label fx:id="lblDashAdherents" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox fx:id="cardRetards" styleClass="card card-red" alignment="CENTER" prefWidth="250" prefHeight="140">
                        <Label text="⚠ Retards en cours"/>
                        <Label fx:id="lblDashRetards" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox fx:id="cardMois" styleClass="card rounded" alignment="CENTER" prefWidth="250" prefHeight="140">
                        <Label text="🗓 Emprunts du mois"/>
                        <Label fx:id="lblDashMois" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
                <HBox spacing="12" style="-fx-padding: 8 0 0 0;">
                    <Label text="Statistiques (profil)" styleClass="text-muted"/>
                    <Label text="• Utilisateurs actifs:" styleClass="text-muted"/>
                    <Label fx:id="lblStatUsers" />
                    <Label text="• Catégories:" styleClass="text-muted"/>
                    <Label fx:id="lblStatCategories" />
                    <Label text="• Emprunts en cours:" styleClass="text-muted"/>
                    <Label fx:id="lblStatEmprunts" />
                </HBox>
                <Label text="Liste des retards" styleClass="text-muted"/>
                <TableView fx:id="tableRetards" prefHeight="260.0">
                    <columns>
                        <TableColumn fx:id="colRLivre" text="Livre" prefWidth="240"/>
                        <TableColumn fx:id="colRAdherent" text="Adhérent" prefWidth="200"/>
                        <TableColumn fx:id="colRDateLimite" text="Date limite" prefWidth="140"/>
                        <TableColumn fx:id="colRJours" text="Jours de retard" prefWidth="140"/>
                        <TableColumn fx:id="colRPenalite" text="Pénalité (FCFA)" prefWidth="140"/>
                    </columns>
                </TableView>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
